        <!-- Flow numbers -->
        <mxCell id="flow_box" value="&lt;b&gt;Execution Flow:&lt;/b&gt;  ❶ Developer triggers pipeline → ❷ ADO dispatches to self-hosted agent pool → ❸ Agent picks up job, installs Terraform → ❹ Secrets injected from Variable Group as env vars → ❺ Terraform connects to bastion/clusters via SSH + API → ❻ Infrastructure provisioned on bare metal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#90A4AE;fontSize=10;fontColor=#333333;arcSize=8;align=left;spacingLeft=10;spacingRight=10;" vertex="1" parent="1">
