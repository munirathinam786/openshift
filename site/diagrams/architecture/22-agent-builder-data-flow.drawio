  <diagram id="agent-builder-dataflow" name="Agent Builder Data Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="&lt;b&gt;Agent Builder — Data Flow: Agent Creation to Deployment&lt;/b&gt;&lt;br&gt;&lt;i&gt;End-to-end workflow from user design to live agent on OpenShift&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="1000" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="&lt;b&gt;1. Design Agent&lt;/b&gt;" style="swimlane;startSize=35;fillColor=#2E7D32;fontColor=#FFFFFF;strokeColor=#2E7D32;rounded=1;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="260" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="s1a" value="&lt;b&gt;Agent Builder UI&lt;/b&gt;&lt;br&gt;&lt;i&gt;Visual drag-and-drop&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=11;fontStyle=0;fontColor=#333333;arcSize=10;" vertex="1" parent="step1">
          <mxGeometry x="15" y="45" width="230" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s1b" value="Define: name, tools,&lt;br&gt;system prompt, model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;fontStyle=0;fontColor=#333333;arcSize=10;" vertex="1" parent="step1">
          <mxGeometry x="15" y="100" width="230" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;2. Save &amp; Configure&lt;/b&gt;" style="swimlane;startSize=35;fillColor=#1565C0;fontColor=#FFFFFF;strokeColor=#1565C0;rounded=1;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="310" y="80" width="260" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="s2a" value="&lt;b&gt;Agent Builder API&lt;/b&gt;&lt;br&gt;&lt;i&gt;POST /agents&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;fontStyle=0;fontColor=#333333;arcSize=10;" vertex="1" parent="step2">
          <mxGeometry x="15" y="45" width="230" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s2b" value="Save to &lt;b&gt;MongoDB&lt;/b&gt;&lt;br&gt;Register in &lt;b&gt;Agent Registry&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;fontStyle=0;fontColor=#333333;arcSize=10;" vertex="1" parent="step2">
          <mxGeometry x="15" y="100" width="230" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;3. Orchestrate Workflow&lt;/b&gt;" style="swimlane;startSize=35;fillColor=#7B1FA2;fontColor=#FFFFFF;strokeColor=#7B1FA2;rounded=1;fontSize=13;fontStyle=1;whiteSpace=wrap;html=1;container=1;collapsible=0;" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="260" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="s3a" value="&lt;b&gt;Temporal Server&lt;/b&gt;&lt;br&gt;&lt;i&gt;Workflow Execution&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=11;fontStyle=0;fontColor=#333333;arcSize=10;" vertex="1" parent="step3">
          <mxGeometry x="15" y="45" width="230" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="s3b" value="&lt;b&gt;Temporal Workers&lt;/b&gt;&lt;br&gt;Execute activities:&lt;br&gt;LLM calls, tool runs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=11;fontStyle=0;fontColor=#333333;arcSize=10;" vertex="1" parent="step3">
