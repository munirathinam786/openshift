<mxfile host="app.diagrams.net" modified="2026-05-06T10:00:00.000Z" agent="GitHub Copilot" version="24.7.17"><diagram id="azure-aro-flow" name="Azure ARO Deployment Flow"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="&lt;b&gt;Azure Red Hat OpenShift Deployment Flow&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1" vertex="1" parent="1"><mxGeometry x="440" y="20" width="600" height="30" as="geometry"/></mxCell><mxCell id="s1" value="1. Terraform creates the resource group, VNet, and two empty subnets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=13;" vertex="1" parent="1"><mxGeometry x="120" y="120" width="330" height="70" as="geometry"/></mxCell><mxCell id="s2" value="2. Terraform creates or reuses the Microsoft Entra service principal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C2185B;fontSize=13;" vertex="1" parent="1"><mxGeometry x="500" y="120" width="330" height="70" as="geometry"/></mxCell><mxCell id="s3" value="3. Terraform grants Contributor and Network Contributor RBAC roles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=13;" vertex="1" parent="1"><mxGeometry x="880" y="120" width="330" height="70" as="geometry"/></mxCell><mxCell id="s4" value="4. azurerm_redhat_openshift_cluster provisions the managed ARO cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=13;" vertex="1" parent="1"><mxGeometry x="120" y="280" width="330" height="70" as="geometry"/></mxCell><mxCell id="s5" value="5. Terraform renders preflight, kubeconfig, DNS, and delete helper assets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0277BD;fontSize=13;" vertex="1" parent="1"><mxGeometry x="500" y="280" width="330" height="70" as="geometry"/></mxCell><mxCell id="s6" value="6. Azure DevOps optionally fetches the admin kubeconfig" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=13;" vertex="1" parent="1"><mxGeometry x="880" y="280" width="330" height="70" as="geometry"/></mxCell><mxCell id="s7" value="7. Operators validate console and API access with az and oc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=13;" vertex="1" parent="1"><mxGeometry x="300" y="440" width="340" height="70" as="geometry"/></mxCell><mxCell id="s8" value="8. Optional Azure DNS helper adds api and *.apps records" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F8E9;strokeColor=#689F38;fontSize=13;" vertex="1" parent="1"><mxGeometry x="710" y="440" width="360" height="70" as="geometry"/></mxCell><mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s5" target="s6"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s6" target="s7"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#546E7A;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="s7" target="s8"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>