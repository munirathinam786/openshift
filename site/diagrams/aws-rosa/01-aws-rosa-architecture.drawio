<mxfile host="app.diagrams.net" modified="2026-05-06T10:00:00.000Z" agent="GitHub Copilot" version="24.7.17"><diagram id="aws-rosa-architecture" name="AWS ROSA Architecture"><mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="&lt;b&gt;OpenShift on AWS (ROSA) Architecture&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=20;fontStyle=1" vertex="1" parent="1"><mxGeometry x="450" y="20" width="500" height="30" as="geometry"/></mxCell><mxCell id="aws" value="&lt;b&gt;AWS Account&lt;/b&gt;&lt;br&gt;Customer-owned VPC and IAM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#EF6C00;fontSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="80" width="980" height="560" as="geometry"/></mxCell><mxCell id="vpc" value="&lt;b&gt;ROSA VPC&lt;/b&gt;&lt;br&gt;Public and private subnets across 3 AZs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=13;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="600" height="420" as="geometry"/></mxCell><mxCell id="public" value="&lt;b&gt;Public Subnets&lt;/b&gt;&lt;br&gt;NAT gateways + internet-facing ALBs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;" vertex="1" parent="1"><mxGeometry x="110" y="190" width="240" height="120" as="geometry"/></mxCell><mxCell id="private" value="&lt;b&gt;Private Subnets&lt;/b&gt;&lt;br&gt;ROSA worker nodes and internal services" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=12;" vertex="1" parent="1"><mxGeometry x="390" y="190" width="240" height="120" as="geometry"/></mxCell><mxCell id="endpoints" value="&lt;b&gt;VPC Endpoints&lt;/b&gt;&lt;br&gt;STS, EC2, ECR, ELB, Logs, Monitoring, Route53, S3" style="rounded=1;whit