        <mxCell id="r1a" value="Provider" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="85" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r1b" value="hashicorp/aws&#xa;hashicorp/azurerm" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="85" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r1c" value="hashicorp/null&#xa;hashicorp/local&#xa;hashicorp/tls (reserved)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="85" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r1d" value="No cloud API exists;&#xa;servers are physical hardware" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="85" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r2a" value="Authentication" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="140" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r2b" value="API keys / IAM roles&#xa;Stored in env vars or vault" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="140" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r2c" value="SSH private key&#xa;Authenticates to bastion host" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="140" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r2d" value="Air-gapped = no cloud IAM;&#xa;SSH is the only entry point" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r3a" value="Creates&#xa;Resources?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="195" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r3b" value="Yes -- VMs, VPCs, LBs, DNS&#xa;Cloud API creates infrastructure" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="195" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r3c" value="No -- Servers pre-provisioned&#xa;Terraform orchestrates, not creates" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="195" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r3d" value="Hardware team racks servers;&#xa;Terraform configures them" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="195" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r4a" value="Network" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="250" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r4b" value="Public internet to cloud API&#xa;HTTPS REST calls" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="250" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r4c" value="Air-gapped private network&#xa;SSH via bastion (10.142.41.10)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="250" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r4d" value="Data center has no internet;&#xa;security policy requirement" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="250" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r5a" value="State Tracking" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="305" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r5b" value="Tracks cloud resource IDs&#xa;(i-0abc..., vpc-123...)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="305" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r5c" value="Tracks trigger hashes&#xa;Re-runs when input changes" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="305" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r5d" value="null_resource has no real ID;&#xa;uses triggers map instead" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="305" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r6a" value="terraform&#xa;destroy" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="360" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r6b" value="Deletes VMs, VPCs, LBs&#xa;Full cleanup via API" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="360" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r6c" value="Only removes state tracking&#xa;Physical servers remain powered on" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="360" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r6d" value="Cannot decommission hardware&#xa;via API -- manual process" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="360" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r7a" value="Infrastructure&#xa;Lifecycle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;fontColor=#37474F;strokeColor=#B0BEC5;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="415" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r7b" value="Fully managed by Terraform&#xa;Create + Update + Delete" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E3F2FD;fontColor=#0D47A1;strokeColor=#90CAF9;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="415" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r7c" value="Configuration only&#xa;Hardware managed separately" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFEBEE;fontColor=#B71C1C;strokeColor=#EF9A9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="415" width="290" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="r7d" value="Different teams own hardware&#xa;vs. software deployment" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8F5E9;fontColor=#1B5E20;strokeColor=#A5D6A7;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="415" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="summary" value="Key Takeaway: This project uses Terraform as an orchestration engine, not as an infrastructure creator.&#xa;The null provider runs commands on remote hosts via SSH. The local provider generates configuration files. No cloud API is involved." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;fontColor=#37474F;strokeColor=#FFD54F;fontSize=10;fontStyle=0;arcSize=5;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="10" y="490" width="950" height="45" as="geometry"/>
        </mxCell>
