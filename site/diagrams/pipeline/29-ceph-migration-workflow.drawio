        </mxCell>
        <!-- Step 1 -->
        <mxCell id="5" value="1. PREPARE&#xa;Enable RBD Mirroring&#xa;on Source" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="200" height="70" as="geometry"/>
        </mxCell>
        <!-- Step 2 -->
        <mxCell id="6" value="2. PREPARE&#xa;Enable RBD Mirroring&#xa;on Destination" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="230" width="200" height="70" as="geometry"/>
        </mxCell>
        <!-- Step 3 -->
        <mxCell id="7" value="3. PREPARE&#xa;Create MirrorPeer&#xa;+ Label PVCs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="540" y="230" width="200" height="70" as="geometry"/>
        </mxCell>
        <!-- Step 4 -->
        <mxCell id="8" value="4. VALIDATE&#xa;Check sync status&#xa;daemon &amp; image health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="230" width="200" height="70" as="geometry"/>
        </mxCell>
        <!-- Replication Arrow -->
        <mxCell id="9" value="RBD Mirroring&#xa;(Async/Sync)" style="shape=flexArrow;endArrow=classic;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
