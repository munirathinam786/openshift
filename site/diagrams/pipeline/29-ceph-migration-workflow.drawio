        <!-- Step 5 -->
        <mxCell id="10" value="5. MIGRATE&#xa;Fence Source Workloads&#xa;(scale to 0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="370" width="200" height="70" as="geometry"/>
        </mxCell>
        <!-- Step 6 -->
