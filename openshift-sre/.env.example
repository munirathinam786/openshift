# For local CLI usage, localhost is correct.
# For Podman on macOS, override at runtime with:
# OLLAMA_BASE_URL=http://host.containers.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
# Example alternatives for structured-output capable local models:
# LOCAL_MODEL_NAME=llama3:8b
# LOCAL_MODEL_NAME=qwen2.5:14b
LOCAL_MODEL_NAME=gemma4:26b
OPENSHIFT_CLUSTER=local-cluster
OPENSHIFT_NAMESPACE=openshift-monitoring
# Optional comma-separated default project list for watchlists or project sweeps.
OPENSHIFT_PROJECTS=
# Optional explicit Kubernetes API endpoint and bearer token.
OPENSHIFT_API_URL=
OPENSHIFT_TOKEN=
# Optional kubeconfig settings. When omitted, the runtime uses ~/.kube/config.
KUBECONFIG_PATH=
KUBECONFIG_CONTEXT=
OC_CLI_PATH=oc
# Set to false only if your cluster endpoint uses a certificate chain the runtime cannot validate.
OPENSHIFT_VERIFY_SSL=true
ALLOW_MUTATING_ACTIONS=false
AGENT_MAX_STEPS=8

# Historical metrics storage. Leave DATABASE_ENABLED=false for local runs without MariaDB.
DATABASE_ENABLED=false
# Optional full SQLAlchemy URL override. Example:
# DATABASE_URL=mysql+pymysql://openshift_sre_agent:change-me@db:3306/openshift_sre_agent
DATABASE_URL=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=openshift_sre_agent
DB_USER=openshift_sre_agent
DB_PASSWORD=change-me

# OpenShift Architect knowledge base and draw.io export support.
ARCHITECT_RAG_ENABLED=false
# Optional full PostgreSQL URL override. Example:
# ARCHITECT_VECTOR_DATABASE_URL=postgresql://openshift_sre_architect:change-me-vector@vector-db:5432/openshift_sre_architect
ARCHITECT_VECTOR_DATABASE_URL=
ARCHITECT_VECTOR_DB_HOST=localhost
ARCHITECT_VECTOR_DB_PORT=5432
ARCHITECT_VECTOR_DB_NAME=openshift_sre_architect
ARCHITECT_VECTOR_DB_USER=openshift_sre_architect
ARCHITECT_VECTOR_DB_PASSWORD=change-me-vector
ARCHITECT_EMBEDDING_MODEL=nomic-embed-text
ARCHITECT_RAG_TOP_K=5

# ── v0.3.0 settings ─────────────────────────────────────────────────────────
# API authentication (leave blank to disable auth)
API_KEY=
# Prompt template: default | incident_commander | platform_engineer | security_auditor | change_manager
PROMPT_TEMPLATE=default
# Data retention (days, 0 = unlimited)
DATA_RETENTION_DAYS=90
# Prometheus metrics endpoint
ENABLE_PROMETHEUS=false
# Model tuning
CONTEXT_WINDOW_TOKENS=4096
# TEMPERATURE_OVERRIDE=
# Rate limiting
RATE_LIMIT_RPM=30
