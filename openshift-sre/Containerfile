FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive \
    PIP_TRUSTED_HOST="pypi.org pypi.python.org files.pythonhosted.org"

ARG DRAWIO_VERSION=24.7.17

WORKDIR /app

COPY pyproject.toml README.md mkdocs.yml ./
COPY src ./src
COPY docs ./docs

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        fonts-liberation \
        libasound2 \
        libatk-bridge2.0-0 \
        libatk1.0-0 \
        libcairo2 \
        libdrm2 \
        libgbm1 \
        libgtk-3-0 \
        libnotify4 \
        libnss3 \
        libpango-1.0-0 \
        libsecret-1-0 \
        libx11-xcb1 \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxkbcommon0 \
        libxrandr2 \
        libxss1 \
        libxtst6 \
        tesseract-ocr \
        wget \
        xdg-utils \
        xvfb && \
    arch="$(dpkg --print-architecture)" && \
    case "$arch" in \
        amd64) drawio_pkg="drawio-amd64-${DRAWIO_VERSION}.deb" ;; \
        arm64|aarch64) drawio_pkg="drawio-arm64-${DRAWIO_VERSION}.deb" ;; \
        *) echo "Unsupported architecture for draw.io package: $arch" >&2; exit 1 ;; \
    esac && \
    wget -O /tmp/drawio.deb "https://github.com/jgraph/drawio-desktop/releases/download/v${DRAWIO_VERSION}/${drawio_pkg}" && \
    apt-get install -y /tmp/drawio.deb && \
    rm -f /tmp/drawio.deb && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/* && \
    python -m pip install --upgrade pip && \
    python -m pip install --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org '.[docs]' && \
    mkdocs build

EXPOSE 8000

CMD ["python", "-m", "openshift_sre_agent.cli", "serve", "--host", "0.0.0.0", "--port", "8000"]
