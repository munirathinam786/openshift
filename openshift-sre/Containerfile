FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_TRUSTED_HOST="pypi.org pypi.python.org files.pythonhosted.org"

WORKDIR /app

COPY pyproject.toml README.md mkdocs.yml ./
COPY src ./src
COPY docs ./docs

RUN python -m pip install --upgrade pip && \
    python -m pip install --trusted-host pypi.org --trusted-host pypi.python.org --trusted-host files.pythonhosted.org '.[docs]' && \
    mkdocs build

EXPOSE 8000

CMD ["python", "-m", "aws_sre_agent.cli", "serve", "--host", "0.0.0.0", "--port", "8000"]
