          <mxGeometry x="400" y="20" width="500" height="35" as="geometry" />
        </mxCell>

        <!-- Steps -->
        <mxCell id="c1" value="1. Client sends&#xa;POST /chat&#xa;{prompt, runtime?, conversation_id?}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="2. CORS → Rate Limiter → Tracing&#xa;inject X-Request-Id&#xa;check token bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="90" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="3. Validate prompt length&#xa;≤ 4 000 chars&#xa;(Pydantic max_length)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="90" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="4. Settings.with_overrides(runtime)&#xa;per-request config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="850" y="90" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="c5" value="5. Load conversation memory&#xa;if conversation_id present:&#xa;  get_conversation_turns(id, 5)&#xa;  agent.set_conversation_context(turns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="260" height="80" as="geometry" />
        </mxCell>
        <mxCell id="c6" value="6. agent.ask(prompt)&#xa;→ reasoning loop&#xa;(see Agent Loop page)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="220" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="c7" value="7. record_chat(&#xa;  prompt, answer, steps,&#xa;  model, region, duration,&#xa;  conversation_id&#xa;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="c8" value="8. _broadcast_ws({&#xa;  type: &quot;run_completed&quot;,&#xa;  run_id, confidence,&#xa;  duration_ms, model&#xa;})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="890" y="220" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="c9" value="9. Return ChatResponse&#xa;{answer, steps, run_id,&#xa; confidence: 0.0–1.0}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="380" width="260" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="ec1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c2" target="c3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c3" target="c4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c4" target="c5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1100" y="180" /><mxPoint x="170" y="180" /></Array></mxGeometry></mxCell>
        <mxCell id="ec5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c5" target="c6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c6" target="c7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c7" target="c8"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="c8" target="c9"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1130" y="360" /><mxPoint x="590" y="360" /></Array></mxGeometry></mxCell>

        <!-- ── SSE variant note ── -->
        <mxCell id="sse_note" value="SSE Variant (/chat/stream):  Same flow but step 6 yields&#xa;&#34;data: {type:step, …}&#34; per step, then &#34;data: {type:done, …}&#34;" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;size=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="370" height="55" as="geometry" />
        </mxCell>

        <!-- ── WebSocket delivery ── -->
        <mxCell id="ws_note" value="Connected WS clients (history dashboard)&#xa;receive the broadcast and auto-reload charts" style="shape=note;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;size=16;" vertex="1" parent="1">
          <mxGeometry x="780" y="380" width="320" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ════════════════════════════════════════════════════════════════
       PAGE 3 — Agent Reasoning Loop
       ════════════════════════════════════════════════════════════════ -->
  <diagram id="page-agent-loop" name="Agent Reasoning Loop">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t3" value="Agent Reasoning Loop (agent.py — AwsSreAgent.ask)" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="550" height="35" as="geometry" />
        </mxCell>

        <!-- Start -->
        <mxCell id="a_start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="70" width="100" height="40" as="geometry" />
        </mxCell>

        <mxCell id="a_build" value="Build messages:&#xa;[system_prompt + tool_manifest]&#xa;+ conversation_context turns&#xa;+ user prompt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="510" y="140" width="230" height="70" as="geometry" />
        </mxCell>

        <mxCell id="a_loop" value="step ≤ max_steps ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="250" width="170" height="60" as="geometry" />
        </mxCell>

        <mxCell id="a_llm" value="OllamaClient.chat(messages)&#xa;→ raw JSON string" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="510" y="360" width="230" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a_parse" value="_parse_envelope(raw)&#xa;→ {thought, tool_call, final_answer}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="510" y="450" width="230" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a_decision" value="tool_call?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="540" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- Tool branch -->
        <mxCell id="a_invoke" value="AwsSreToolkit.invoke(name, args)&#xa;(check cache → call handler → cache result)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="540" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="a_append" value="Append tool result&#xa;to messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="180" y="440" width="210" height="45" as="geometry" />
        </mxCell>

        <!-- Final answer branch -->
        <mxCell id="a_final" value="final_answer present?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="810" y="540" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="a_missing" value="Required tools&#xa;all called?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="830" y="650" width="140" height="60" as="geometry" />
        </mxCell>

        <mxCell id="a_score" value="_compute_confidence(steps)&#xa;→ 0.0 – 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1060" y="650" width="200" height="45" as="geometry" />
        </mxCell>

        <mxCell id="a_return" value="Return AgentResult&#xa;{answer, steps, tool_names,&#xa; duration_ms, confidence}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="740" width="230" height="60" as="geometry" />
        </mxCell>

        <mxCell id="a_force" value="Force model to call&#xa;missing tools → retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="810" y="760" width="170" height="45" as="geometry" />
        </mxCell>

        <mxCell id="a_exhaust" value="max_steps exhausted:&#xa;return partial + confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="250" width="210" height="50" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_start" target="a_build"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_build" target="a_loop"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea3" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_loop" target="a_llm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea3b" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#999999;" edge="1" parent="1" source="a_loop" target="a_exhaust"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_llm" target="a_parse"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_parse" target="a_decision"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea6" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#d79b00;" edge="1" parent="1" source="a_decision" target="a_invoke"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#d79b00;" edge="1" parent="1" source="a_invoke" target="a_append"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea8" value="loop back" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#d79b00;" edge="1" parent="1" source="a_append" target="a_loop"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="130" y="463" /><mxPoint x="130" y="280" /><mxPoint x="540" y="280" /></Array></mxGeometry></mxCell>
        <mxCell id="ea9" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_decision" target="a_final"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea10" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="a_final" target="a_missing"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea11" value="all done" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="a_missing" target="a_score"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="a_score" target="a_return"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea13" value="missing" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#d6b656;" edge="1" parent="1" source="a_missing" target="a_force"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#d6b656;dashed=1;" edge="1" parent="1" source="a_force" target="a_loop"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="895" y="840" /><mxPoint x="80" y="840" /><mxPoint x="80" y="280" /><mxPoint x="540" y="280" /></Array></mxGeometry></mxCell>

        <!-- Legend: Retry / Fallback box -->
        <mxCell id="retry_box" value="OllamaClient internals:&#xa;1. Try primary model&#xa;2. Retry with backoff (3×, 1.5ⁿ s)&#xa;3. If circuit opens → try fallback models&#xa;4. Circuit resets after 30 s" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;size=16;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="100" width="280" height="100" as="geometry" />
        </mxCell>

        <mxCell id="cache_box" value="Tool Cache:&#xa;• SHA-256 key from (name, args)&#xa;• 60 s TTL — skip AWS API call if cached&#xa;• Module-level singleton" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;size=16;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1060" y="230" width="280" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ════════════════════════════════════════════════════════════════
       PAGE 4 — Resilience: Circuit Breaker + Retry + Fallback
       ════════════════════════════════════════════════════════════════ -->
  <diagram id="page-resilience" name="Resilience Patterns">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t4" value="Resilience Patterns — model_client.py" style="text;html=1;fontSize=20;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="500" height="35" as="geometry" />
        </mxCell>

        <!-- ── Circuit Breaker State Machine ── -->
        <mxCell id="cb_title" value="Circuit Breaker State Machine" style="text;html=1;fontSize=15;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="cb_closed" value="CLOSED&#xa;(normal traffic)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cb_open" value="OPEN&#xa;(reject all)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cb_half" value="HALF-OPEN&#xa;(allow one probe)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="280" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ecb1" value="3 consecutive&#xa;failures" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#b85450;fontSize=10;" edge="1" parent="1" source="cb_closed" target="cb_open"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ecb2" value="30 s elapsed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#d6b656;fontSize=10;" edge="1" parent="1" source="cb_open" target="cb_half"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ecb3" value="success" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#82b366;fontSize=10;" edge="1" parent="1" source="cb_half" target="cb_closed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ecb4" value="failure" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#b85450;fontSize=10;curved=1;" edge="1" parent="1" source="cb_half" target="cb_open"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="500" y="315" /></Array></mxGeometry></mxCell>

        <!-- ── Retry + Fallback Flow ── -->
        <mxCell id="rf_title" value="Retry + Multi-Model Fallback" style="text;html=1;fontSize=15;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="660" y="80" width="300" height="25" as="geometry" />
        </mxCell>
        <mxCell id="rf1" value="chat(messages)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="120" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf2" value="models = [primary] + fallback_models" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="190" width="240" height="35" as="geometry" />
        </mxCell>
        <mxCell id="rf3" value="FOR each model:" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="260" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rf4" value="Circuit open?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="730" y="340" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rf5" value="Attempt 1..3&#xa;POST /api/chat&#xa;backoff: 1.5ⁿ s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="430" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="rf6" value="Success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="440" width="120" height="35" as="geometry" />
        </mxCell>
        <mxCell id="rf7" value="All models failed&#xa;→ raise error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1000" y="260" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="rf_skip" value="skip → next model" style="text;html=1;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="940" y="350" width="130" height="20" as="geometry" />
        </mxCell>
        <mxCell id="erf1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="rf1" target="rf2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erf2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="rf2" target="rf3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erf3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="rf3" target="rf4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erf4" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;" edge="1" parent="1" source="rf4" target="rf5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erf5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#b85450;" edge="1" parent="1" source="rf4" target="rf_skip"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="erf6" value="ok" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeWidth=2;strokeColor=#82b366;" edge="1" parent="1" source="rf5" target="rf6"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ── Confidence Legend ── -->
        <mxCell id="conf_title" value="Confidence Scoring" style="text;html=1;fontSize=15;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="conf_box" value="score = (successful_calls / total_steps) × 0.7&#xa;        − (error_steps / total_steps) × 0.3&#xa;        + 0.3 if final_answer present&#xa;&#xa;Clamped [0.0, 1.0]&#xa;&#xa;  ≥ 0.7  →  🟢 High    (green badge)&#xa;  ≥ 0.4  →  🟡 Medium  (amber badge)&#xa;  &lt; 0.4  →  🔴 Low     (red badge)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;size=16;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="455" width="380" height="165" as="geometry" />
        </mxCell>

        <!-- ── Connection Pool Legend ── -->
        <mxCell id="pool_title" value="DB Connection Pool" style="text;html=1;fontSize=15;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="pool_box" value="pool_size = 5   (persistent connections)&#xa;max_overflow = 10   (burst → max 15)&#xa;pool_recycle = 1800 s   (30 min)&#xa;pool_pre_ping = True   (validate before use)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;size=16;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="685" width="350" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

